{
  "name": "domorium",
  "version": "1.0.0",
  "description": "GEDCOM editing tools for the web, Visual Studio Code, and JetBrains IDEs",
  "scripts": {
    "build:libs": "npm run build -w packages/lsp",
    "build:vscode": "npm run build -w apps/vscode",
    "test": "vitest",
    "test:run": "vitest --run",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "check:typescript": "npm run lint && npm run typecheck && npm run test:run",
    "check:jetbrains": "./apps/jetbrains/gradlew -p apps/jetbrains spotlessCheck test",
    "check": "npm run check:typescript && npm run check:jetbrains",
    "format:staged": "lefthook run pre-commit",
    "postinstall": "npm run build:libs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.6",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "private": true
}
